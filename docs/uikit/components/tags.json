  "recreationGuide": {
    "description": "How to recreate tags using text-to-figma tools",
    "notificationBadge": "const badge = create_frame({ name: 'Notification Badge', layoutMode: 'HORIZONTAL', padding: 4, horizontalSizing: 'HUG', verticalSizing: 'FIXED', height: 24 }); set_fills({ nodeId: badge.frameId, color: '#DD1717' }); set_corner_radius({ nodeId: badge.frameId, radius: 12 }); const count = create_text({ content: '1', parentId: badge.frameId, fontSize: 14, fontWeight: 700, color: '#FFFFFF' });",
    "labelTag": "const tag = create_frame({ name: 'New Tag', layoutMode: 'HORIZONTAL', padding: 8, itemSpacing: 4, horizontalSizing: 'HUG', verticalSizing: 'FIXED', height: 24 }); // For gradient: add_gradient_fill({ nodeId: tag.frameId, type: 'LINEAR', angle: 90, stops: [{ position: 0, color: '#C6FF77' }, { position: 1, color: '#25ECFF' }] }); // For solid: set_fills({ nodeId: tag.frameId, color: '#FF6B00' }); set_corner_radius({ nodeId: tag.frameId, radius: 4 }); const tagText = create_text({ content: 'NEW', parentId: tag.frameId, fontSize: 12, fontWeight: 700, color: '#1D092F' }); set_text_case({ nodeId: tagText.nodeId, textCase: 'UPPER' });"
  },
