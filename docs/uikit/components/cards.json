  "cardPatterns": {
    "standardCard": {
      "description": "Basic card structure pattern",
      "structure": [
        "1. Container frame with cornerRadius and shadow",
        "2. Optional image/background at top",
        "3. Content area with padding",
        "4. Optional action buttons at bottom"
      ],
      "styling": {
        "cornerRadius": 8,
        "background": { "ref": "base100", "hex": "#FFFFFF" },
        "border": { "ref": "base70", "hex": "#CEB6D8", "width": 1 },
        "shadow": "elevation-1 or elevation-2",
        "padding": { "horizontal": 16, "vertical": 16 }
      }
    },
    "imageCard": {
      "description": "Card with prominent image",
      "structure": [
        "1. Image at top (no padding)",
        "2. Content below image with padding",
        "3. Optional footer/actions"
      ],
      "cornerRadius": {
        "outer": 8,
        "image": "8 8 0 0 (rounded top only)"
      }
    },
    "selectionCard": {
      "description": "Card with selection state",
      "states": {
        "default": {
          "border": { "ref": "base70", "hex": "#CEB6D8", "width": 1 }
        },
        "selected": {
          "border": { "ref": "brandAccentPrimary", "hex": "#25ECFF", "width": 2 }
        },
        "hover": {
          "border": { "ref": "brandAccentPrimary", "hex": "#25ECFF", "width": 1 }
        }
      }
    }
  },
  "recreationGuide": {
    "description": "Step-by-step guide to recreate card components using text-to-figma tools",
    "thumbnail": {
      "steps": [
        "1. Create frame: width=112, height=149, cornerRadius=8",
        "2. Apply image fill: set_image_fill with game image URL",
        "3. Add shadow: apply_effects with DROP_SHADOW (y=2, blur=8, opacity=0.15)",
        "4. Optional: Add overlay gradient for better text contrast"
      ],
      "example": "create_frame + set_corner_radius + set_image_fill + apply_effects"
    },
    "paymentCard": {
      "steps": [
        "1. Create root frame: layoutMode=HORIZONTAL, width=370, height=66, padding(h=16,v=12), itemSpacing=12",
        "2. Set background: base100 (#FFFFFF), cornerRadius=8",
        "3. Add border: base70 (#CEB6D8), width=1",
        "4. Add radio button instance (left)",
        "5. Add card logo instance (payment method)",
        "6. Create info frame: layoutMode=VERTICAL, itemSpacing=4",
        "7. Add card number text: fontSize=14, fontWeight=500",
        "8. Add expiry text: fontSize=12, fontWeight=400, color=base40",
        "9. Add action buttons frame: layoutMode=HORIZONTAL, itemSpacing=8",
        "10. Add edit and delete icon buttons",
        "11. For selected state: change border to brandAccentPrimary (#25ECFF), width=2"
      ]
    },
    "coinPack": {
      "steps": [
        "1. Create root frame: width=176, height=264, cornerRadius=12, layoutMode=VERTICAL",
        "2. Add gradient background or image fill",
        "3. Add coin amount text: fontSize=16, fontWeight=700, UPPER case, centered",
        "4. Add divider line",
        "5. Add offer title text: fontSize=12, fontWeight=700, UPPER case",
        "6. Add coin icon image",
        "7. Add discount button instance at bottom",
        "8. Apply shadow: y=4, blur=16, opacity=0.2"
      ]
    },
    "standardCard": {
      "steps": [
        "1. Create frame with fixed or HUG sizing",
        "2. Set cornerRadius=8",
        "3. Set background=base100 (#FFFFFF)",
        "4. Add border: base70 (#CEB6D8), width=1",
        "5. Set padding based on content (typically 16px)",
        "6. Add shadow for elevation",
        "7. Add content frames/text inside",
        "8. For interactive states, modify border color/width"
      ]
    }
  },
  "_extraction_notes": {
    "methodology": "Cards extracted from Figma page 'Cards' (ID: 1089:852)",
    "componentSets": {
      "thumbnail": "1246:1516 - 38 game thumbnail variants",
      "paymentCard": "1280:1889 - 2 states (default, selected)",
      "coinPack": "3085:8544 - 7 coin pack types",
      "specialOffer": "3085:9092 - Special promotional cards",
      "provider": "2169:117 - Provider filter cards"
    },
    "status": "COMPLETE - Core card components documented with structure and styles",
    "usage": "Cards are container components with consistent styling patterns. Use thumbnail for game display, paymentCard for payment methods, coinPack for purchases. All support hover/selection states with border color changes.",
    "patterns": "Standard card pattern: cornerRadius=8, shadow for elevation, border for structure, padding for content. Selection indicated by border color change to brandAccentPrimary."
  }
}
