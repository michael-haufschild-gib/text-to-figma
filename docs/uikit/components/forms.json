  "formPatterns": {
    "standardForm": {
      "description": "Typical form layout pattern",
      "structure": [
        "1. Form title (H3 or H4)",
        "2. Form description (optional, p)",
        "3. Input fields with labels",
        "4. Checkbox/Radio groups",
        "5. Action buttons (Primary + Secondary)"
      ],
      "spacing": {
        "betweenFields": 24,
        "betweenSections": 32,
        "betweenButtonsAndForm": 32,
        "betweenButtons": 16
      }
    },
    "inlineForm": {
      "description": "Compact inline form",
      "layout": "HORIZONTAL",
      "spacing": {
        "betweenFields": 16
      }
    }
  },
  "recreationGuide": {
    "description": "Step-by-step guide to recreate form components using text-to-figma tools",
    "input": {
      "steps": [
        "1. Create root frame: layoutMode=VERTICAL, itemSpacing=4, width=320",
        "2. Add top help text frame: create_text with fontSize=12, color=base60 (#A88FB6)",
        "3. Create field frame: layoutMode=HORIZONTAL, itemSpacing=8",
        "4. Add leading icon (optional): 16x16 icon instance",
        "5. Add input text: fontSize=16, color=base40 (#8C6C9C) for placeholder",
        "6. Add trailing icon (optional): 16x16 icon instance",
        "7. Add bottom help text frame: same as top",
        "8. For states, modify border and text colors accordingly",
        "9. Error state: add border (systemError #DD1717, width=2), change help text color",
        "10. Focus state: add border (brandAccentPrimary #25ECFF, width=2) + glow effect",
        "11. Success state: add border (systemSuccess #11DF16, width=2)"
      ],
      "example": "create_frame + create_text (label) + create_frame (field) + create_text (input) + create_text (help)"
    },
    "checkbox": {
      "steps": [
        "1. Create 20x20 frame with cornerRadius=4",
        "2. Unchecked: transparent background, border (base40 #8C6C9C, width=2)",
        "3. Checked: fill=brandAccentPrimary (#25ECFF), add check icon (base0 #1D092F)",
        "4. Add label text at 8px spacing: fontSize=14, fontWeight=400"
      ]
    },
    "radio": {
      "steps": [
        "1. Create 20x20 ellipse (cornerRadius=50%)",
        "2. Unselected: transparent background, border (base40 #8C6C9C, width=2)",
        "3. Selected: fill=brandAccentPrimary (#25ECFF)",
        "4. Add inner 8x8 ellipse in center (base0 #1D092F) for selected state",
        "5. Add label text at 8px spacing: fontSize=14, fontWeight=400"
      ]
    },
    "pill": {
      "steps": [
        "1. Create frame: layoutMode=HORIZONTAL, padding(h=16, v=8), cornerRadius=18",
        "2. Default: transparent background, border (base40 #8C6C9C, width=2)",
        "3. Selected: fill=brandAccentPrimary (#25ECFF), no border",
        "4. Add text: fontSize=14, fontWeight=400, color=base0 (#1D092F)"
      ]
    },
    "selector": {
      "steps": [
        "1. Create button frame: width=320, height=48, padding(h=16, v=12), cornerRadius=8",
        "2. Background: base100 (#FFFFFF), border (base70 #CEB6D8, width=1)",
        "3. Add text: fontSize=16, fontWeight=400, color=base0 (#1D092F)",
        "4. Add chevron-down icon (trailing)",
        "5. For dropdown: create frame below with options, elevation-2 shadow",
        "6. Option items: padding(h=16, v=12), hover background=base95 (#F5F1F7)"
      ]
    }
  },
