  "recreationGuide": {
    "description": "How to recreate switches using text-to-figma tools",
    "step1_createTrack": "const track = create_frame({ name: 'Switch Track', width: 48, height: 24, layoutMode: 'HORIZONTAL', padding: 2, horizontalSizing: 'FIXED', verticalSizing: 'FIXED' }); set_fills({ nodeId: track.frameId, color: '#3D1F50' }); // Off state set_corner_radius({ nodeId: track.frameId, radius: 12 }); // Pill shape",
    "step2_createKnob": "const knob = create_ellipse({ width: 20, height: 20, fillColor: '#CEB6D8', parentId: track.frameId }); // Off state",
    "step3_alignKnob": "set_layout_align({ nodeId: track.frameId, primaryAxis: 'MIN', counterAxis: 'CENTER' }); // Knob on left for off state",
    "step4_forOnState": "// For on state: set_fills({ nodeId: track.frameId, color: '#C6FF77' }); set_fills({ nodeId: knob.nodeId, color: '#1D092F' }); set_layout_align({ nodeId: track.frameId, primaryAxis: 'MAX', counterAxis: 'CENTER' }); // Knob on right",
    "step5_sizing": "// SM: 40×20 (knob 16×16), MD: 48×24 (knob 20×20), LG: 56×28 (knob 24×24)"
  },
