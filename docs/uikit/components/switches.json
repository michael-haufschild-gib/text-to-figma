    "structure": {
      "track": {
        "description": "Background pill shape",
        "cornerRadius": "50% (pill shape)",
        "offColor": "#3D1F50",
        "onColor": "#C6FF77",
        "transition": "background-color 0.2s ease"
      },
      "knob": {
        "description": "Circular toggle element",
        "shape": "circle",
        "offColor": "#CEB6D8",
        "onColor": "#1D092F",
        "offPosition": "2px from left",
        "onPosition": "2px from right",
        "transition": "transform 0.2s ease, background-color 0.2s ease"
      }
    },
    "styling": {
      "cornerRadius": "50% (pill shape)",
      "transition": "0.2s ease for all properties"
    }
