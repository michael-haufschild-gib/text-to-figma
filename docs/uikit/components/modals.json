  "modalPatterns": {
    "standardModal": {
      "description": "Three-section modal structure",
      "structure": [
        "1. Header: Title, optional subtitle, close button",
        "2. Body: Main content area (scrollable if needed)",
        "3. Footer: Action buttons (typically Primary + Secondary)"
      ],
      "spacing": {
        "padding": 24,
        "itemSpacing": 16,
        "buttonSpacing": 16
      },
      "sizing": {
        "minWidth": 320,
        "maxWidth": 600,
        "mobile": 343,
        "tablet": 400,
        "desktop": 480
      }
    },
    "confirmationModal": {
      "description": "Simple confirmation dialog",
      "structure": [
        "1. Header with warning/info icon",
        "2. Body with question/confirmation text",
        "3. Footer with Cancel + Confirm buttons"
      ],
      "sizing": {
        "width": 400,
        "compact": true
      }
    },
    "formModal": {
      "description": "Modal containing a form",
      "structure": [
        "1. Header with form title",
        "2. Body with form fields (from forms.json)",
        "3. Footer with Cancel + Submit buttons"
      ],
      "bodySpacing": {
        "fieldSpacing": 24,
        "sectionSpacing": 32
      }
    }
  },
