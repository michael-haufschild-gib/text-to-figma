      "zIndex": 1000
    },
    "interaction": {
      "clickOutside": "Close modal when clicking overlay",
      "escapeKey": "Close modal on ESC key press"
    }
  },
  "recreationGuide": {
    "description": "Step-by-step guide to recreate modal components using text-to-figma tools",
    "informationalModal": {
      "steps": [
        "1. Create overlay frame: width=100% viewport, height=100% viewport, fill=base0 (#1D092F, opacity=0.6)",
        "2. Create modal root frame: layoutMode=VERTICAL, width=366, cornerRadius=16, background=base100 (#FFFFFF)",
        "3. Apply shadow: apply_effects with DROP_SHADOW (y=8, blur=32, opacity=0.25)",
        "4. CREATE HEADER SECTION:",
        "   a. Create header frame: layoutMode=HORIZONTAL, padding(h=24, v=20), itemSpacing=12, justifyContent=space-between",
        "   b. Add title frame: layoutMode=VERTICAL, itemSpacing=4",
        "   c. Add title text: fontSize=20, fontWeight=700, color=base0 (#1D092F)",
        "   d. Add subtitle text (optional): fontSize=14, fontWeight=400, color=base40 (#8C6C9C)",
        "   e. Add close button icon: 24x24, position=absolute top-right",
        "   f. Add border-bottom: base90 (#E5DBE9), width=1",
        "5. CREATE BODY SECTION:",
        "   a. Create body frame: layoutMode=VERTICAL, padding(h=24, v=20), itemSpacing=16",
        "   b. Add content frame: layoutMode=VERTICAL, itemSpacing=12",
        "   c. Add body text: fontSize=14, fontWeight=400, lineHeight=21, color=base20 (#5A3E68)",
        "   d. Add any form fields or additional content from forms.json",
        "6. CREATE FOOTER SECTION:",
        "   a. Create footer frame: layoutMode=VERTICAL, padding(h=24, v=20)",
        "   b. Add actions frame: layoutMode=HORIZONTAL, itemSpacing=16, justifyContent=flex-end",
        "   c. Add secondary button: Type=Secondary, Size=MD",
        "   d. Add primary button: Type=Primary, Size=MD",
        "   e. Add border-top: base90 (#E5DBE9), width=1",
        "7. Position modal: center horizontally and vertically in viewport"
      ],
      "example": "create_frame (overlay) + create_frame (modal) + set_corner_radius + apply_effects + create_frame (header/body/footer) + create_text + create_instance (buttons)"
    },
    "marketingModal": {
      "steps": [
        "1. Create overlay frame (same as informational)",
        "2. Create modal root frame: layoutMode=VERTICAL, width=383, cornerRadius=16, background=base100 (#FFFFFF)",
        "3. Apply shadow: apply_effects with DROP_SHADOW (y=8, blur=32, opacity=0.25)",
        "4. CREATE HEADER SECTION:",
        "   a. Add hero image: width=383, height=200, cornerRadius=16 16 0 0",
        "   b. Apply image fill: set_image_fill with promotional image",
        "   c. Add close button: 32x32 circle, background=base100 (opacity=0.9), position=absolute top-right",
        "5. CREATE BODY SECTION:",
        "   a. Create body frame: layoutMode=VERTICAL, padding=24, itemSpacing=16",
        "   b. Add title text: fontSize=24, fontWeight=700, textAlign=CENTER, color=base0",
        "   c. Add description text: fontSize=16, fontWeight=400, lineHeight=24, textAlign=CENTER, color=base20",
        "6. CREATE FOOTER SECTION:",
        "   a. Create footer frame: layoutMode=VERTICAL, padding=24, itemSpacing=12",
        "   b. Add primary CTA button: Type=Primary, Size=LG, full-width",
        "   c. Add secondary CTA (optional): Type=Ghost, Size=MD, full-width",
        "7. Position modal: center in viewport"
      ]
    },
    "modalWithForm": {
      "steps": [
        "1. Follow informational modal structure (steps 1-4)",
        "2. In body section, add form fields:",
        "   a. For each input field, use input structure from forms.json",
        "   b. Add label: fontSize=12, fontWeight=400, color=base60 (#A88FB6)",
        "   c. Add input field: width=318 (full width with padding), height=48",
        "   d. Add help text: fontSize=12, fontWeight=400, color=base60",
        "   e. Space between fields: 24px",
        "3. In footer, change button labels:",
        "   a. Secondary button: 'Cancel'",
        "   b. Primary button: 'Submit' or specific action",
        "4. Example: Login modal with 2 inputs (email + password) + checkbox ('Remember me') + 2 buttons"
      ]
    },
    "quickExample": {
      "simpleConfirmation": [
        "create_frame(overlay) → create_frame(modal, width=400, cornerRadius=16) → apply_effects(shadow) →",
        "create_frame(header, padding=24) → create_text('Are you sure?', h3) → create_instance(close_button) →",
        "create_frame(body, padding=24) → create_text('This action cannot be undone', p) →",
        "create_frame(footer, padding=24) → create_instance(button, 'Cancel', Secondary) → create_instance(button, 'Confirm', Primary)"
      ]
    }
  },
  "_extraction_notes": {
    "methodology": "Modals extracted from Figma page 'Modals' (ID: 77:668)",
    "componentSets": {
      "informationalPopup": "1281:2140 - Standard modal with header/body/footer",
      "marketingPopup": "1364:3007 - Rich promotional modal with hero image",
      "headerComponent": "1281:2060 - Reusable modal header",
      "bodyComponent": "1281:2059 - Reusable modal body",
      "footerComponent": "1281:2058 - Reusable modal footer"
    },
    "status": "COMPLETE - Core modal components documented with structure and patterns",
    "usage": "Modals are overlay components that interrupt the user flow. Use informational for alerts/confirmations, marketing for promotions. Always include overlay backdrop, center positioning, and close mechanisms (X button + ESC key + click outside).",
    "integration": "Modals can contain any combination of components: forms (forms.json), buttons (buttons.json), cards (cards.json). Body section is flexible and can be customized based on content needs.",
    "patterns": "Standard 3-section structure (Header/Body/Footer) with consistent spacing (24px padding, 16px itemSpacing). Header and footer have borders for visual separation. Shadow elevation-4 for prominence."
  }
