  "recreationGuide": {
    "description": "How to use icons in your designs",
    "standardIcon": {
      "steps": [
        "1. Icons are created as component instances",
        "2. Standard size: 24×24px (some payment icons: 40×24px, loyalty: 32×32px)",
        "3. Color: Apply fill color using set_fills tool",
        "4. Usage: create_instance with icon component ID, then set_fills for color",
        "5. For buttons: Place icon in auto-layout frame with text"
      ],
      "example": "create_instance({ componentId: '61:574' }) + set_fills({ color: '#1D092F' })"
    },
    "iconInButton": {
      "steps": [
        "1. Create button frame (horizontal auto-layout)",
        "2. Add icon instance as first or last child",
        "3. Add text label",
        "4. Set itemSpacing: 8px between icon and text",
        "5. Icon color should match text color"
      ],
      "example": "Button with search icon: create_frame + create_instance(search) + create_text"
    },
    "iconInInput": {
      "steps": [
        "1. Create input field frame (horizontal layout)",
        "2. Add leading icon instance (16×16px)",
        "3. Add input text",
        "4. Add trailing icon instance (16×16px)",
        "5. Set itemSpacing: 8px",
        "6. Icon colors: base40 (#8C6C9C) for default, adjust for states"
      ]
    },
