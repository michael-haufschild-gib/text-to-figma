{
  "extends": "../mcp-server/tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "**/*.ts",
    "../mcp-server/src/**/*.ts",
    "../figma-plugin/src/**/*.ts",
    "../vitest-globals.d.ts"
  ],
  "files": ["../node_modules/@figma/plugin-typings/plugin-api.d.ts"],
  "exclude": ["node_modules", "dist"]
}
