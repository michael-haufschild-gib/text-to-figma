{
  "name": "text-to-figma-websocket-server",
  "version": "1.0.0",
  "description": "WebSocket bridge server for Text-to-Figma MCP integration",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc -w & node --watch dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "keywords": [
    "websocket",
    "figma",
    "mcp",
    "bridge"
  ],
  "author": "Michael Haufschild",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-haufschild-gib/text-to-figma",
    "directory": "websocket-server"
  },
  "homepage": "https://github.com/michael-haufschild-gib/text-to-figma#readme",
  "bugs": {
    "url": "https://github.com/michael-haufschild-gib/text-to-figma/issues"
  },
  "license": "MIT",
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
