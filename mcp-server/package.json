{
  "name": "text-to-figma-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Text-to-Figma with design constraints",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "text-to-figma-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "npm run test:all",
    "test:unit": "cd ../tests && node --test unit/**/*.test.js",
    "test:integration": "cd ../tests && node --test integration/**/*.test.js",
    "test:e2e": "cd ../tests && node --test e2e/**/*.test.js",
    "test:validation": "cd ../tests && node --test validation/**/*.test.js",
    "test:all": "npm run build && npm run test:unit && npm run test:integration && npm run test:validation",
    "test:coverage": "c8 npm run test:all",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "keywords": [
    "mcp",
    "figma",
    "design-system"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "c8": "^9.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-jsdoc": "^61.1.5",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  }
}
