{
  "name": "text-to-figma-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Text-to-Figma with design constraints",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "text-to-figma-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config ../vitest.workspace.ts --project mcp-server-unit",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "keywords": [
    "mcp",
    "figma",
    "design-system"
  ],
  "author": "Michael Haufschild",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-haufschild-gib/text-to-figma",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/michael-haufschild-gib/text-to-figma#readme",
  "bugs": {
    "url": "https://github.com/michael-haufschild-gib/text-to-figma/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1"
  }
}
